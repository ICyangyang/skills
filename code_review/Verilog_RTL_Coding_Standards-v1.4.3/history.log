  2. 规则数据库 (verilog_standards.json)                                                  
2. 规则数据库 (verilog_standards.json)                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                        
  将你的规范转换为结构化JSON：                                                                            

  {                                                                                                       
    "format_rules": {                                                                                     
      "file_header": {                                                                                    
        "level": "R",                                                                                     
        "rule": "所有Verilog代码都需要有文件头",                                                          
        "fields": ["filename", "author", "created", "description", "history"]                                                                                                                                       
      },                                                                                                  
      "indentation": {                                                                                    
        "level": "S",                                                                                     
        "rule": "缩进使用Space而非Tab，建议4个Space"                                                      
      },                                                                                                  
      "line_length": {                                                                                    
        "level": "S",                                                                                     
        "rule": "每行小于等于120个字符",                                                                  
        "max_length": 120                                                                                 
      }                                                                                                   
    },                                                                                                    
    "naming_rules": {                                                                                     
      "signal_naming": {                                                                                  
        "level": "S",                                                                                     
        "rules": [                                                                                        
          "直观、简洁、有含义",                                                                           
          "使用下划线分隔不同含义",                                                                       
          "不超过30字符",                                                                                 
          "只允许字母数字下划线",                                                                         
          "字母开头",                                                                                     
          "小写命名",                                                                                     
          "不使用保留字"                                                                                  
        ]                                                                                                 
      },                                                                                                  
      "suffixes": {                                                                                       
        "_n": "低有效",                                                                                   
        "_clk": "时钟信号",                                                                               
        "_en": "使能",                                                                                    
        "_r": "打拍寄存器"                                                                                
      },                                                                                                  
      "abbreviations": {                                                                                  
        "clk": "clock",                                                                                   
        "rst": "reset",                                                                                   
        "en": "enable",                                                                                   
        "vld": "valid",                                                                                   
        "addr": "address"                                                                                 
      }                                                                                                   
    },                                                                                                    
    "design_rules": {                                                                                     
      "sequential_logic": {                                                                               
        "level": "R",                                                                                     
        "rules": [                                                                                        
          "使用非阻塞赋值<=",                                                                             
          "同一寄存器不能在多个always块中赋值",                                                           
          "不能对同一变量覆盖赋值（应使用else if）"                                                       
        ]                                                                                                 
      },                                                                                                  
      "combinational_logic": {                                                                            
        "level": "R",                                                                                     
        "rules": [                                                                                        
          "使用阻塞赋值=",                                                                                
          "敏感列表要列全（可用always @(*)）",                                                            
          "避免产生Latch（需要default或完整条件）"                                                        
        ]                                                                                                 
      },                                                                                                  
      "clock_design": {                                                                                   
        "level": "R",                                                                                     
        "rules": [                                                                                        
          "禁止在内部模块中使用组合逻辑产生时钟",                                                         
          "时钟信号只能连接到寄存器时钟端",                                                               
          "每个always块只允许一个clock"                                                                   
        ]                                                                                                 
      },                                                                                                  
      "reset_design": {                                                                                   
        "level": "R",                                                                                     
        "rules": [                                                                                        
          "采用异步复位",                                                                                 
          "复位信号应为低电平有效",                                                                       
          "复位值必须是常量"                                                                              
        ]                                                                                                 
      }                                                                                                   
    }                                                                             3. 分阶段Prompt设计                                                                                     

  阶段1：格式检查 (prompts/format.md)                                                                     

  # Verilog代码格式审查                                                                                   

  ## 任务                                                                                                 
  审查Verilog代码的格式是否符合规范要求。                                                                 

  ## 审查项目                                                                                             
  1. 文件头完整性（filename, author, created, description, history）                                      
  2. 缩进是否使用空格（非Tab）                                                                            
  3. 行长度是否≤120字符                                                                                   
  4. 信号定义对齐                                                                                         
  5. 模块例化对齐                                                                                         

  ## 输出格式                                                                                             
  对每个问题，提供：                                                                                      
  - 文件位置（行号）                                                                                      
  - 违反的规则                                                                                            
  - 级别（Rule/Suggestion）                                                                               
  - 修改建议                                                                                              

  ## 规则来源                                                                                             
  参考：Verilog_RTL_Coding_Standards-v1.4.3.md 第5条                                                      

  阶段2：命名检查 (prompts/naming.md)                                                                     

  # Verilog命名规范审查                                                                                   

  ## 任务                                                                                                 
  检查信号、端口、参数、宏定义的命名规范。                                                                

  ## 检查项                                                                                               
  1. 信号命名是否符合规范（小写、下划线、有含义）                                                         
  2. 是否使用标准缩写（参考abbreviations表）                                                              
  3. 后缀使用是否正确（_n, _clk, _en, _r等）                                                              
  4. 是否超过30字符                                                                                       
  5. 是否使用了保留字                                                                                     
  6. 宏定义是否全大写                                                                                     
  7. parameter是否全大写                                                                                  

  ## 输出格式                                                                                             
  - 信号名称                                                                                              
  - 位置（模块名:行号）                                                                                   
  - 问题类型                                                                                              
  - 建议的命名                                                                                            

  阶段3：设计规则检查 (prompts/design.md)                                                                 

  # Verilog设计规则审查                                                                                   

  ## 任务                                                                                                 
  检查代码中的设计规则违反情况。                                                                          

  ## 关键检查区域                                                                                         

  ### 时序逻辑                                                                                            
  - [ ] 使用非阻塞赋值<=                                                                                  
  - [ ] 无同一寄存器多处赋值                                                                              
  - [ ] 无覆盖式赋值（应使用else if）                                                                     
  - [ ] 复位逻辑使用else if                                                                               

  ### 组合逻辑                                                                                            
  - [ ] 使用阻塞赋值=                                                                                     
  - [ ] 敏感列表完整（always @(*)）                                                                       
  - [ ] 无Latch产生（default/完整条件）                                                                   
  - [ ] 避免组合逻辑反馈回路                                                                              

  ### 时钟设计                                                                                            
  - [ ] 无组合逻辑产生时钟                                                                                
  - [ ] 时钟只接寄存器时钟端                                                                              
  - [ ] 单always块单clock                                                                                 

  ### 复位设计                                                                                            
  - [ ] 异步复位低电平有效                                                                                
  - [ ] 复位值为常量                                                                                      
  - [ ] 多变量复位完整                                                                                    

  ## 输出格式                                                                                             
  分类输出，标注严重程度（Critical/Error/Warning/Info）                                                   

  阶段4：专用深度检查 (prompts/clock_reset.md)                                                            

阶段4：专用深度检查 (prompts/clock_reset.md)                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                                                                        
  # 时钟和复位专项审查                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                          
  ## 任务                                                                                                 
  对时钟和复位设计进行深度检查，这些是芯片设计的critical部分。                                            
                                                                                                          
  ## 检查清单                                                                                             
                                                                                                          
  ### 时钟域                                                                                              
  - [ ] 跨时钟域信号是否使用common_sync                                                                   
  - [ ] 单bit信号至少两级寄存器同步                                                                       
  - [ ] 跨时钟域第一级后缀为_asyn                                                                         
  - [ ] 无组合逻辑输出跨时钟域                                                                            
  - [ ] 时序对齐操作在跨时钟域前完成                                                                      
                                                                                                          
  ### 复位                                                                                                
  - [ ] 跨时钟域复位先同步                                                                                
  - [ ] scan模式下复位可bypass                                                                            
  - [ ] 无同步异步复位组合逻辑                                                                            
  - [ ] 单bit控制信号需要复位                                                                             
  - [ ] 单always块不超过1个复位                                                                           
                                                                                                          
  ## 输出要求                                                                                             
  对每个潜在问题，提供：                                                                                  
  - 风险等级（Critical/High/Medium/Low）                                                                  
  - 可能的故障场景                                                                                        
  - 推荐修复方案                                                                                          
  - 参考规范条款                                                                                          
                                                                                                          
  4. 输出模板 (template.md)                                                                               

