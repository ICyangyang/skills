    "description": "Review Verilog RTL code against team coding standards",                                                                                                                                                                                                               
    "version": "1.0.0",                                                                                                                                                                                                                                                                   
    "author": "Your Team",                                                                                                                                                                                                                                                                
    "capabilities": [                                                                                                                                                                                                                                                                     
      "code_review",                                                                                                                                                                                                                                                                      
      "rule_checking",                                                                                                                                                                                                                                                                    
      "suggestion_generation"                                                                                                                                                                                                                                                             
