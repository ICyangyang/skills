    {
      "id": 44,
      "category": "电路设计规范",
      "level": "R",
      "check_item": "状态机结构检查",
      "check_method": "状态机是否采用两段式写法（一个时序always块用于状态寄存，一个组合always块用于次态逻辑和输出）",
      "reference": "Verilog_RTL_Coding_Standards-v1.4.3.md 第7条",
      "stage": "STAGE_4_2",
      "expected_value": "是",
      "regex_pattern": null,
      "details": {
        "description": "状态机应采用两段式写法：(1) 时序always块：负责状态寄存，在时钟边沿更新当前状态；(2) 组合always块：根据当前状态和输入计算次态和输出。",
        "example_valid": "// 时序块\nalways @(posedge clk or negedge rst_n)\n    if(~rst_n) cur_state <= ST_IDLE;\n    else cur_state <= nxt_state;\n\n// 组合块\nalways @(*) begin\n    nxt_state = cur_state;\n    case(cur_state) ...\nend",
        "example_invalid": "// 单段式写法不推荐\nalways @(posedge clk or negedge rst_n) begin\n    if(~rst_n) ...\n    else case(cur_state) ...\nend"
      }
    },
