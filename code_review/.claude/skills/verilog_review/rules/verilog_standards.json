      "category": "电路设计规范",
      "level": "R",
      "check_item": "状态机默认状态检查",
      "check_method": "状态机case语句中是否有default分支指定默认状态",
      "reference": "Verilog_RTL_Coding_Standards-v1.4.3.md 第7条",
      "stage": "STAGE_4_2",
      "expected_value": "是",
      "regex_pattern": null,
      "details": {
        "description": "状态机必须有default条件，为状态机指定一个默认状态，防止状态机进入死锁状态。",
        "example_valid": "case(cur_state)\n    ST_IDLE: ...\n    ST_PROCESS: ...\n    default: nxt_state = ST_IDLE;\nendcase",
